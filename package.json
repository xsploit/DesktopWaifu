{
	"name": "webwaifu3-electrobun",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev:web": "vite dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run dev:web\" \"bun run dev\"",
		"build:web": "vite build",
		"build": "vite build && electrobun build && bun run scripts/write-windows-manifests.mjs",
		"build:stable": "vite build && electrobun build --env=stable && bun run scripts/write-windows-manifests.mjs",
		"build:canary": "vite build && electrobun build --env=canary && bun run scripts/write-windows-manifests.mjs",
		"build:release": "bun run build:stable",
		"preview": "vite preview",
		"postinstall": "bun run scripts/apply-electrobun-patches.mjs",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "latest",
		"@types/three": "^0.182.0",
		"@vitejs/plugin-basic-ssl": "^2.1.4",
		"concurrently": "^9.1.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@ai-sdk/open-responses": "^1.0.1",
		"@ai-sdk/openai": "^3.0.26",
		"@huggingface/transformers": "^3.8.1",
		"@pixiv/three-vrm": "^3.4.5",
		"@vercel/analytics": "^1.6.1",
		"ai": "^6.0.77",
		"electrobun": "1.15.1",
		"fish-audio": "^0.0.3",
		"kokoro-js": "^1.2.1",
		"phonemizer": "^1.2.1",
		"three": "^0.182.0",
		"wlipsync": "^1.3.0"
	}
}
